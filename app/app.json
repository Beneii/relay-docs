      "router": {}
    },
    "updates": {
      "url": "https://u.expo.dev/9bf57379-4be3-4fa6-ae80-55feb35eab5c"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "benei"
  }
}
