{
  "name": "relay-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:app": "npm --prefix app run typecheck",
    "lint": "npm --prefix app run lint",
    "test:web": "node --test --experimental-strip-types tests/**/*.test.ts",
    "test:app": "npm --prefix app run test -- --runInBand --watchman=false",
    "test": "npm run test:web && npm run test:app",
    "build": "vite build",
    "preview": "vite preview",
    "verify": "npm run typecheck && npm run typecheck:app && npm run lint && npm run test:web && npm run build && npm run test:app"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/node": "^5.6.11",
    "supabase": "^2.77.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}
