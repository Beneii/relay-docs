{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.ts": {
      "includeFiles": "api/_lib/**"
    }
  },
  "crons": [
    {
      "path": "/api/heartbeat-check",
      "schedule": "* * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/notify/:token",
      "destination": "https://wvlbdjpllcnmndkujzpy.supabase.co/functions/v1/notify/:token"
    },
    {
      "source": "/auth/callback",
      "destination": "/auth/callback.html"
    },
    {
      "source": "/((?!api|assets|favicon\\.svg|auth).*)",
      "destination": "/index.html"
    }
  ]
}
